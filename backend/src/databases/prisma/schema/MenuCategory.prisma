model MenuCategory {

  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  menuId    String   @db.ObjectId
  menu      Menu     @relation(fields: [menuId], references: [id])

  name        String
  description String?
 
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)

  items MenuItem[]

   @@index([menuId])
  @@unique([menuId, name])

  @@map("menu_categories")
}