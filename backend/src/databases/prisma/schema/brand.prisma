model Brand {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String       @unique
  logo        String?
  email_contact  String?
  phone_contact  String?
  description  String?
  tax_code    String?
  link        String?
  imageMain   String
  images      String[]
  isActive    isActive     @default(ACTIVE)
  address     String?
  isFeatured  Boolean @default(false) // 👈 tiêu biểu
  new        Boolean @default(true)
  restaurants Restaurant[] // 1 Brand có nhiều Nhà hàng
  employments Employment[] // Nhân sự cấp Brand
  menu        Menu[]
  items       MenuItem[]
  paymentConfigs RestaurantPaymentConfig[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@index([isActive])
  @@index([createdAt])
  @@index([isActive, isFeatured])
  @@map("brands")
}